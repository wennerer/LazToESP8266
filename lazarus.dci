[inittime | initialises a time server [uses time_server, esp_sntp]]
$(AttributesStart)
EnableMakros=true
KeepSubIndent=true
$(AttributesEnd)
|//var Stat : Tsntp_sync_status;
initTime;
repeat
 sleep (100);
 Stat := sntp_get_sync_status;
until Stat = SNTP_SYNC_STATUS_COMPLETED;


