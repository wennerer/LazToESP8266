Start_Timer(|xTimerHandle,Interval);

[Stop_Timer | Stop and free a xTimer ESP8266]
$(AttributesStart)
EnableMakros=true
KeepSubIndent=true
$(AttributesEnd)
procedure Stop_Timer(xTimerHandle: TTimerHandle);
begin
 if xTimerStop(xTimerHandle, 0) <> pdPASS then
  writeln('The timer could not be stopped')
 else
  xTimerDelete(xTimerHandle, 0);
end;

